    "@nestjs/throttler": "^6.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node-cron": "^3.0.11",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.3.0",
