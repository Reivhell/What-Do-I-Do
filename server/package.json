    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
